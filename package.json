{
  "name": "decode-codex",
  "private": true,
  "version": "0.1.0",
  "description": "Reverse-engineering workspace for the OpenAI Codex macOS app.",
  "scripts": {
    "test": "cd .agents/skills/deobfuscate-javascript && bun test",
    "typecheck": "cd .agents/skills/deobfuscate-javascript && bun tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "format": "echo 'No formatter configured yet'",
    "docs:check": "node scripts/check-docs.mjs",
    "check": "pnpm run typecheck && pnpm run test && pnpm run docs:check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
